                                <p class="lineTotal mx-3" value="@item.ProductsItem.Price"> Total: $@(item.ProductsItem.Price * item.Quantity)</p>
                            }
                            else if (item.ProductsItem?.ItemName == "Colgate Total Toothpaste Original")
                            {
                                <img src="~/ImageItem/SelfCare1.jpg" style="width: 50px; height: 50px;" />
                                <input type="hidden" name="id" value="@item.Id" />
                                <button class="minus-button btn btn-success"> - </button>
                                <p class="qty" name="Quantity">@item.Quantity</p>
                                <button class="plus-button btn btn-success"> + </button>
                                <p class="lineTotal mx-3" value="@item.ProductsItem.Price"> Total: $@(item.ProductsItem.Price * item.Quantity)</p>
                            }
                        }
                        <button type="button" value="@item.Id" class="remove-button btn btn-success bg-transparent">
                            Remove
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}

<footer class="cartfooter border-top" id="example1">
    
    <p id="modalTotal">Cart Total: $0.00</p>
    @{
        if (Model != null)
        {
            <button type="button" value="@Model.Id" id="btnClearCart" class="button-item-add btn btn-danger bg-transparent">
                Clear Cart
            </button>
            <button type="button" value="@Model.Id" id="btnCheckOut" class="button-item-add btn btn-success bg-transparent">
                Check Out
            </button>
        }
    }
</footer>
