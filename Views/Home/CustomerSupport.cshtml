<div class="support-container theme-text">
    <section id="contact-info">
        <h3>Contact Information</h3>
        <p>If you need assistance, please feel free to reach out to us using the following contact details:</p>
        <ul>
            <li><strong>Email:</strong> uptownITinc@support.com</li>
            <li><strong>Phone:</strong> 1-800-123-4567</li>
            <li><strong>Address:</strong> 1234 Support St, Help City, HC 12345</li>
        </ul>
    </section>

    <section id="support-hours">
        <h3>Support Hours</h3>
        <p>Our support team is available during the following hours:</p>
        <ul>
            <li><strong>Monday - Friday:</strong> 9:00 AM - 6:00 PM</li>
            <li><strong>Saturday:</strong> 10:00 AM - 4:00 PM</li>
            <li><strong>Sunday:</strong> Closed</li>
        </ul>
    </section>

    <section id="company-info">
        <h3>Company Details</h3>
        <p><strong>Company Name:</strong> Uptown IT Inc.</p>
        <p><strong>Founded:</strong> 2010</p>
        <p><strong>Mission:</strong> To provide the best customer support and services to our valued customers.</p>
    </section>

    <section id="additional-support">
        <h3>Additional Support</h3>
        <p>If you need further assistance, please visit our <a href="/faq">FAQ page</a> or our <a href="/support">Support Center</a>.</p>
    </section>
</div>

<style>
    .support-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 20px;
    }

    ul {
        list-style-type: none;
        padding: 0;
    }

        ul li {
            margin-bottom: 10px;
        }
