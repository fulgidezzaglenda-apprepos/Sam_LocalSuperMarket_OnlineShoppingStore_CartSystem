@model Sam_LocalSuperMarket_OnlineShoppingStore1.Data.CreateUserDTO
   
@{
	ViewData["Title"] = "CreateUser";
}

<h4 class="theme-text">Create an Account</h4>

<hr />

<div class="row">
    <form class="item-qty-form d-flex justify-content-md-start">
        <img src="~/Image/logo.jpg" style="width: 75px; height: 75px;" />
        <h3 class="theme-text"> Welcome to Sam's Local Supermarket </h4>
    </form>
</div>

<div class="row">
    <div class="col-md-4">
        <form asp-action="CreateUser">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="UserName" class="control-label theme-text" style="font-size:x-large; font-style:italic;"></label>
                <input asp-for="UserName" class="form-control" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Password" class="control-label theme-text" style="font-size:x-large; font-style:italic;"></label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PasswordConfirmation" class="control-label theme-text" style="font-size:x-large; font-style:italic;"></label>
                <input asp-for="PasswordConfirmation" class="form-control" />
                <span asp-validation-for="PasswordConfirmation" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Sign Up" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="UserLogin" asp-controller="UserLogin">Back to Sign In</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
