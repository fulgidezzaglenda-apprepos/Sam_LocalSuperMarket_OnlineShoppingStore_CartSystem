@using Sam_LocalSuperMarket_OnlineShoppingStore1.Models;

@model IEnumerable<Products>

@{
    ViewData["Title"] = "Baked";
    int Id = int.Parse(@Context.Request.RouteValues["id"].ToString());

    bool Authenticated = Context.User != null && Context.User.Identity.IsAuthenticated;
    string SessionId = Context.Session.Id;

    // Retrieve the last products search from session state, or set it to an empty string if it's null
    string lastSearch = Context.Session.GetString("LastProductsSearch") ?? "";

    // Clear the last products search in session state
    Context.Session.SetString("LastProductsSearch", "");
}

<!--Creates a right floated container-->
<div style="float:inline-end" id="showSearchForm">
    <!--Creates a medium column with a width of 9/12 its parent-->
    <div class="col-md-9">
        <!--Create a form which will trigger the ShowSearchResults action event-->
        <form asp-action="ShowSearchResults">
            <div class="form-group">
                <label for="SearchPhrase">Search for:</label>
                <!-- Set the value of the search phrase input to the last products search -->
                <input name="SearchPhrase" value="@lastSearch" class="form-control" />
            </div>
            <div class="form-group">
                <!-- Create a submit button to submit the search form -->
                <input type="submit" value="Search" />
            </div>
        </form>
    </div>
</div>

<h2 class="theme-text"> Baked Goods </h2>
<h5 class="theme-text">"Buying baked goods at the supermarket is like making new friends – warm and inviting, with the promise of delightful 
      conversations with your taste buds!" 🍞🍰😄!</h5>
<hr />

<div>
    @Html.ActionLink("Back to List", "Category", "Home")
</div>

<div class="card-container row" style="display: flex; justify-content: center; align-items: center;">
    @foreach (var products in Model)
    {
        <div class="single-card card shadow m-2 text-center" style="width: 18rem; height: 20rem; object-fit: cover; background-color:lightskyblue;
                    display:flex; justify-content:center; align-items:center">
            <div>
                @if (products.ItemName == "Arnott's Scotch Finger")
                {
                    <img src="~/ImageItem/Baked1.jpg" class="product-image" style="background-image:none;"/>
                    <h5>@products.ItemName</h5>
                    <h6>@products.Unit | $@products.Price</h6>
                    <a id="btnCreate" class="add-item-button btn btn-success" value="@products.Id">Add To Cart</a>
                }
                else if (products.ItemName == "Arnott's TimTam Original Chocolate")
                {
                    <img src="~/ImageItem/Baked2.jpg" class="product-image" />
                    <h5>@products.ItemName</h5>
                    <h6>@products.Unit | $@products.Price</h6>
                    <a id="btnCreate" class="add-item-button btn btn-success" value="@products.Id">Add To Cart</a>
                }
                else if (products.ItemName == "Cheddar Shapes")
                {
                    <img src="~/ImageItem/Baked3.jpg" class="product-image" />
                    <h5>@products.ItemName</h5>
                    <h6>@products.Unit | $@products.Price</h6>
                    <a id="btnCreate" class="add-item-button btn btn-success" value="@products.Id">Add To Cart</a>
                }
                else if (products.ItemName == "Helga's Wholemeal Bread")
                {
                    <img src="~/ImageItem/Baked4.jpg" class="product-image" />
                    <h5>@products.ItemName</h5>
                    <h6>@products.Unit | $@products.Price</h6>
                    <a id="btnCreate" class="add-item-button btn btn-success" value="@products.Id">Add To Cart</a>
                }
                else if (products.ItemName == "Weet Bix Saniatatium")
                {
                    <img src="~/ImageItem/Baked5.jpg" class="product-image" />
                    <h5>@products.ItemName</h5>
                    <h6>@products.Unit | $@products.Price</h6>
                    <a id="btnCreate" class="add-item-button btn btn-success" value="@products.Id">Add To Cart</a>
                }
            </div>
        </div>
    }
</div>

<script src="~/js/products.js" asp-append-version="true"></script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}