@model Sam_LocalSuperMarket_OnlineShoppingStore1.Models.Products

@{
    ViewData["Title"] = "Show Search Results";
    string lastSearch = Context.Session.GetString("LastProductSearch") ?? "";
}

<h2> Sam's Local Supermarket </h2>
<hr />
<div>
    @Html.ActionLink("Back to List", "Category", "Home")
</div>

<div>
    <h4> Products </h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ItemName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ItemName)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Unit)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Unit)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Price)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Price)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Id)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Id)
            <a id="btnCreate" class="add-item-button btn btn-success" value="@Model.Id">Add To Cart</a>
        </dd>
    </dl>
</div>

<script src="~/js/products.js" asp-append-version="true"></script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
